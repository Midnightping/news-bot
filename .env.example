# Telegram API (from my.telegram.org)
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash
TG_PHONE=your_phone_number_with_country_code

# Gemini API (from Google AI Studio)
GEMINI_API_KEY=your_gemini_key

# Notification Bot (from @BotFather)
NOTIFIER_BOT_TOKEN=your_bot_token
USER_CHAT_ID=your_personal_telegram_chat_id

# Supabase (from Supabase Project Settings)
SUPABASE_URL=your_project_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# X / Twitter API (from Developer Portal)
X_API_KEY=your_api_key
X_API_SECRET=your_api_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_SECRET=your_access_secret
X_BEARER_TOKEN=your_bearer_token

# Bot Settings
POLLING_INTERVAL_MINUTES=15
POSTING_INTERVAL_MINUTES=20
MAX_POSTS_PER_DAY=50
DEBUG=True
